# ==========================================
# API 密钥（请替换为你的实际密钥）
# ==========================================

# 阿里云百炼（通义千问）
DASHSCOPE_API_KEY=your-dashscope-api-key

# 百度 AI 搜索
BAIDU_AI_SEARCH_API_KEY=your-baidu-ai-search-api-key

# 缘份居（八字/占卜/解梦）
YUANFENJU_API_KEY=your-yuanfenju-api-key

# 阿里云 Token Plan（LLM 模型）
LLM_API_KEY=your-llm-api-key

# ==========================================
# 飞书机器人（使用飞书前端时必填）
# ==========================================
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret

# ==========================================
# 服务配置
# ==========================================
# 注意：SERVER_HOST 不要填写，代码会自动检测环境
# Docker 环境：自动绑定 0.0.0.0
# 本地环境：自动绑定 127.0.0.1
SERVER_PORT=8000

# LLM 模型配置
LLM_MODEL_NAME=qwen3.6-flash
LLM_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.2

# TTS 语音配置
TTS_VOICE=Eldric Sage
TTS_MODEL=qwen3-tts-instruct-flash

# Embedding 配置
EMBEDDING_MODEL=text-embedding-v3

# Qdrant 向量数据库
QDRANT_COLLECTION=yunshi_2026

# 注意：REDIS_URL 不要填写，代码会自动检测环境
# Docker 环境：redis://redis:6379
# 本地环境：redis://localhost:6379

# 线程池配置
THREAD_POOL_SIZE=20

# 超时配置（秒）
CHAT_TIMEOUT=120
VOICE_TIMEOUT=120

# 飞书并发配置
FEISHU_MAX_USERS=50
FEISHU_USER_TIMEOUT=300

# ==========================================
# Langfuse 监控（可选，Docker 部署时启用）
# ==========================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
